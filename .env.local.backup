# ============================================
# MineOS Dashboard — Environment Variables
# Minta nilai ini dari Ridho (Backend) di W1!
# ============================================

# Supabase (dari Ridho)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# API Backend (dari Ridho)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# CesiumJS Ion Token — daftar di https://ion.cesium.com (free tier)
NEXT_PUBLIC_CESIUM_ION_TOKEN=YOUR_CESIUM_ION_TOKEN

# Mode Development
NEXT_PUBLIC_USE_MOCK_DATA=true
